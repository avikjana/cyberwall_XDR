# CyberWall XDR – Threat Intelligence Service Configuration
# Copy this file to .env and fill in your API keys

# Redis connection (default matches docker-compose)
REDIS_URL=redis://localhost:6379

# Service port
TI_PORT=5004

# Feed sync interval in minutes
FEED_SYNC_INTERVAL_MINUTES=30

# ─── API Keys (leave blank to disable a provider) ────────────────────────
# Get free API key at https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Get free API key at https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# Get free API key at https://otx.alienvault.com/accounts/signup/
OTX_API_KEY=
